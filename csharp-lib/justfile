# aiomsg (C#) — build & test
#
# Everything runs through the .NET SDK (`dotnet`). The conformance suite builds
# the agent project on its own (see ../conformance) and runs the produced
# `conformance_agent` binary directly.

# Show available recipes.
default:
    @just --list

# Build the whole solution.
build:
    dotnet build

# Run the test suite (protocol unit tests + TCP/TLS integration).
test:
    dotnet test

# Run tests with dotnet-coverage (LCOV output for coverage services).
coverage:
    dotnet tool restore
    dotnet tool run dotnet-coverage collect -f cobertura -o coverage.cobertura.xml -- dotnet test
    python3 ../tools/coverage/cobertura_to_lcov.py coverage.cobertura.xml coverage.lcov Aiomsg

# Set the SDK/package version. Repository commit/tag policy lives at the root.
set-release-version version:
    #!/usr/bin/env bash
    set -euo pipefail
    [[ "{{version}}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]
    sed -i -E 's|<Version>[0-9]+\.[0-9]+\.[0-9]+</Version>|<Version>{{version}}</Version>|' Aiomsg/Aiomsg.csproj

# Run an example: `just run server`, `just run client`, or `just run tls`.
run example:
    dotnet run --project Examples -- {{example}}

# Run the conformance agent, e.g.: just agent --role bind --port 25000 ...
agent *ARGS:
    dotnet run --project ConformanceAgent -- {{ARGS}}
