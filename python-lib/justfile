# Common dev operations for aiomsg.
# Run `just` (or `just --list`) to see available recipes.

# Show available recipes.
default:
    @just --list

# Sync the venv with all locked dev/test dependencies.
sync:
    uv sync --group test --group lint

# Run the test suite.
test:
    uv run --group test pytest tests/

# Run tests with coverage (lcov output for coveralls).
coverage:
    uv run --group test pytest --cov=aiomsg --cov-report=lcov:coverage.lcov tests/

# Lint with ruff.
lint:
    uv run --group lint ruff check aiomsg tests

# Auto-format with ruff.
fmt:
    uv run --group lint ruff format aiomsg tests

# Set this package's release version and lockfile. Repository commit/tag policy lives at the root.
set-release-version version:
    #!/usr/bin/env bash
    set -euo pipefail
    [[ "{{version}}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]
    uv version --no-sync "{{version}}"
