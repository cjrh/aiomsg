# Dev operations for the Go implementation of aiomsg.
# Run `just` (or `just --list`) to see available recipes.

# Show available recipes.
default:
    @just --list

# Run the test suite.
test:
    go test ./...

# Run all tests, then collect library package coverage (LCOV output for coverage services).
coverage:
    go test ./...
    go test -coverprofile=coverage.out .
    python3 ../tools/coverage/go_to_lcov.py coverage.out coverage.lcov

# Build everything (library, examples, conformance agent).
build:
    go build ./...

# Vet for suspicious constructs.
lint:
    go vet ./...

# Check formatting.
fmt-check:
    test -z "$(gofmt -l .)"

# Auto-format.
fmt:
    gofmt -w .
