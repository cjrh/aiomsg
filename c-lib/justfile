# aiomsg (C) — build & test

build:
    cmake -B build -S . -DCMAKE_BUILD_TYPE=Debug
    cmake --build build

test: build
    ctest --test-dir build --output-on-failure

# Run tests with Clang source coverage (LCOV output for coverage services).
coverage:
    ../tools/coverage/cmake_llvm_lcov.sh . c coverage.lcov src/protocol.c src/aiomsg.c src/ws.c

# Set the CMake project version. Repository commit/tag policy lives at the root.
set-release-version version:
    #!/usr/bin/env bash
    set -euo pipefail
    [[ "{{version}}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]
    sed -i -E 's/(VERSION )[0-9]+\.[0-9]+\.[0-9]+/\1{{version}}/' CMakeLists.txt

# Build and run the two-process demo (server in the background, then client).
examples: build
    ./build/server & echo $! > /tmp/aiomsg-c-server.pid
    sleep 1
    timeout 3 ./build/client || true
    kill $(cat /tmp/aiomsg-c-server.pid) 2>/dev/null || true

# Stage an install tree under ./dist (headers, static lib, pkg-config, CMake config).
install prefix="dist":
    cmake -B build -S . -DCMAKE_INSTALL_PREFIX={{prefix}}
    cmake --build build
    cmake --install build

clean:
    rm -rf build build-coverage dist coverage.lcov
