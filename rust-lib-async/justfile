# Dev operations for the async (tokio) Rust implementation of aiomsg.
# Run `just` (or `just --list`) to see available recipes.

# Show available recipes.
default:
    @just --list

# Run the test suite (unit + integration + doctests).
test:
    cargo test

# Run tests with line coverage (LCOV output for coverage services).
coverage:
    cargo llvm-cov --lib --tests --ignore-filename-regex '(/tests/|/examples/)' --lcov --output-path coverage.lcov

# Build the crate.
build:
    cargo build

# Lint with clippy, treating warnings as errors.
lint:
    cargo clippy --all-targets -- -D warnings

# Check formatting.
fmt-check:
    cargo fmt --check

# Auto-format.
fmt:
    cargo fmt

# Set the package manifest version. Repository commit/tag policy lives at the root.
set-release-version version:
    #!/usr/bin/env bash
    set -euo pipefail
    [[ "{{version}}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]
    sed -i -E '0,/^version = "[0-9]+\.[0-9]+\.[0-9]+"$/s//version = "{{version}}"/' Cargo.toml
    perl -0pi -e 's/(\[\[package\]\]\nname = "aiomsg"\nversion = ")[^"]+/${1}{{version}}/' Cargo.lock
