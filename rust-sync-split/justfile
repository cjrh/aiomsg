# Dev operations for the synchronous (threaded) Rust implementation of aiomsg.
# Run `just` (or `just --list`) to see available recipes.

# Show available recipes.
default:
    @just --list

# Run the test suite (unit + integration + doctests).
test:
    cargo test

# Build the crate.
build:
    cargo build

# Lint with clippy, treating warnings as errors.
lint:
    cargo clippy --all-targets -- -D warnings

# Check formatting.
fmt-check:
    cargo fmt --check

# Auto-format.
fmt:
    cargo fmt
